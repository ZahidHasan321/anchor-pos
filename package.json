{
	"name": "clothing-pos",
	"description": "A modern Point of Sale system for clothing stores",
	"author": {
		"name": "Anchor POS",
		"email": "support@anchorpos.com"
	},
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": "electron-main.cjs",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"dev:electron": "cross-env BUILD_TARGET=electron electron .",
		"build:electron": "cross-env BUILD_TARGET=electron vite build",
		"start:electron": "npm run build:electron && electron .",
		"package:linux": "npm run build:electron && electron-builder build --linux",
		"package:win": "npm run build:electron && electron-builder build --win",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:reset-data": "npx tsx src/lib/server/db/reset-data.ts"
	},
	"build": {
		"compression": "maximum",
		"appId": "com.anchor.pos",
		"productName": "Anchor POS",
		"directories": {
			"output": "dist-electron",
			"buildResources": "resources"
		},
		"publish": {
			"provider": "github",
			"owner": "YOUR_GITHUB_USERNAME",
			"repo": "YOUR_REPO_NAME"
		},
		"files": [
			"build/**/*",
			"static/**/*",
			"electron-main.cjs",
			"preload.cjs",
			"package.json",
			"node_modules/**/*",
			"!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme,test,__tests__,tests,example,examples,out-tsc}",
			"!**/node_modules/.bin",
			"!**/*.{o,obj,d,map,ts}"
		],
		"asarUnpack": [
			"build/**/*"
		],
		"linux": {
			"target": [
				"AppImage"
			],
			"category": "Office"
		},
		"win": {
			"target": "nsis",
			"icon": "resources/icon.ico",
			"extraFiles": [
				".env"
			]
		}
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@internationalized/date": "^3.11.0",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/crypto-js": "^4.2.2",
		"@types/node": "^24",
		"bits-ui": "^2.15.5",
		"clsx": "^2.1.1",
		"cross-env": "^10.1.0",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"electron": "^40.6.0",
		"electron-builder": "^26.8.1",
		"electron-icon-builder": "^2.0.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"mdsvex": "^0.12.6",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-compression": "^0.5.1"
	},
	"dependencies": {
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"chart.js": "^4.5.1",
		"crypto-js": "^4.2.0",
		"dotenv": "^17.3.1",
		"jsbarcode": "^3.12.3",
		"portfinder": "^1.0.38",
		"postgres": "^3.4.8"
	}
}
