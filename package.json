		"vite-plugin-compression": "^0.5.1"
	},
	"dependencies": {
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"@powersync/common": "^1.49.0",
		"@powersync/web": "^1.36.0",
		"bson": "^7.2.0",
		"chart.js": "^4.5.1",
		"crypto-js": "^4.2.0",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"event-iterator": "^2.0.0",
		"jose": "^6.1.3",
		"jsbarcode": "^3.12.3",
